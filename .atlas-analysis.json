  "keyFeatures": [
    "High-performance URL shortening with Redis-backed redirect resolution",
    "Real-time analytics powered by InfluxDB (clicks by country, device, browser)",
    "Live dashboard updates via WebSocket hub",
    "JWT-based authentication with access + refresh token flow",
    "Custom alias support for branded short links",
    "Automatic QR code generation for every short URL",
    "CSV export of analytics metrics",
    "GeoIP click tracking via external service with Redis cache",
    "Plan-based limits (Free: 5 active URLs / 24h analytics; Pro: unlimited)",
    "Docker Compose infrastructure for local development",
    "OpenAPI 3.0 spec with Swagger UI at /docs"
  ],
  "publicApiSurface": [
    "POST /api/v1/auth/register",
    "POST /api/v1/auth/login",
    "POST /api/v1/auth/refresh",
    "GET /api/v1/auth/me",
    "DELETE /api/v1/auth/me",
    "PATCH /api/v1/auth/me/plan",
    "PATCH /api/v1/auth/me/password",
    "GET /api/v1/auth/me/summary",
    "POST /api/v1/urls",
    "GET /api/v1/urls",
    "GET /api/v1/urls/check-alias",
    "GET /api/v1/urls/code/{shortCode}",
    "PATCH /api/v1/urls/{id}/active",
    "DELETE /api/v1/urls/{id}",
    "GET /api/v1/analytics/stats",
    "GET /api/v1/analytics/stats/export",
    "GET /{code}",
    "GET /health",
    "GET /ws"
  ]
